{# templates/emails/client_qrcode.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #0c0e12;
            margin: 0;
            padding: 0;
            color: #f6f6fc;
        }
        .container {
            max-width: 560px;
            margin: 40px auto;
            background-color: #171a1f;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid #46484d;
        }
        .header {
            background: linear-gradient(135deg, #69daff, #00c0ea);
            padding: 40px 40px 30px;
            text-align: center;
        }
        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 900;
            color: #004a5d;
            letter-spacing: -1px;
        }
        .header p {
            margin: 8px 0 0;
            color: #004050;
            font-size: 14px;
            font-weight: 600;
        }
        .body {
            padding: 40px;
        }
        .greeting {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 16px;
            color: #69daff;
        }
        .text {
            color: #aaabb0;
            line-height: 1.7;
            font-size: 15px;
            margin-bottom: 32px;
        }
        .qr-box {
            background-color: #ffffff;
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            margin-bottom: 32px;
        }
        .qr-box img {
            width: 200px;
            height: 200px;
            display: block;
            margin: 0 auto 12px;
        }
        .qr-box p {
            color: #131b2e;
            font-size: 13px;
            font-weight: 600;
            margin: 0;
        }
        .info-box {
            background-color: #1d2025;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 24px;
            border-left: 4px solid #69daff;
        }
        .info-box p {
            margin: 0 0 8px;
            font-size: 14px;
            color: #aaabb0;
        }
        .info-box p:last-child { margin-bottom: 0; }
        .info-box strong { color: #f6f6fc; }
        .warning {
            background-color: #1d2025;
            border-radius: 12px;
            padding: 16px 20px;
            border-left: 4px solid #ff7346;
            margin-bottom: 32px;
        }
        .warning p {
            margin: 0;
            font-size: 13px;
            color: #aaabb0;
        }
        .footer {
            text-align: center;
            padding: 24px 40px;
            border-top: 1px solid #46484d;
        }
        .footer p {
            margin: 0;
            font-size: 12px;
            color: #74757a;
        }
        .footer strong {
            color: #69daff;
        }
    </style>
</head>
<body>
    <div class="container">

        <!-- Header -->
        <div class="header">
            <h1>KINETIC PULSE</h1>
            <p>Votre accès à la salle est prêt</p>
        </div>

        <!-- Body -->
        <div class="body">

            <p class="greeting">Bienvenue, {{ client.firstName }} ! 👋</p>

            <p class="text">
                Votre inscription à <strong>Kinetic Pulse</strong> est confirmée.
                Voici votre <strong>QR code personnel</strong> — c'est votre clé d'accès à la salle.
                Présentez-le à l'entrée à chaque visite.
            </p>

            <!-- QR Code -->
            <div class="qr-box">
                {% if qrCodeUrl %}
                    <img src="{{ qrCodeUrl }}" alt="Votre QR Code" />
                {% else %}
                    <p style="color: #ff7346; font-weight: 600;">QR Code indisponible</p>
                {% endif %}
                <p>Scannez ce code à l'entrée de la salle</p>
            </div>

            <!-- Infos membre -->
            <div class="info-box">
                <p><strong>Nom :</strong> {{ client.firstName }} {{ client.lastName }}</p>
                <p><strong>Email :</strong> {{ client.email }}</p>
                {% if client.phone %}
                <p><strong>Téléphone :</strong> {{ client.phone }}</p>
                {% endif %}
                <p><strong>Inscrit le :</strong> {{ client.registrationDate|date('d/m/Y') }}</p>
            </div>

            <!-- Avertissement -->
            <div class="warning">
                <p>⚠️ <strong>Important :</strong> Ce QR code est personnel et confidentiel. Ne le partagez pas. Il est lié à votre abonnement.</p>
            </div>

            <p class="text">
                Pour toute question, contactez-nous directement à la réception.
                À très bientôt à la salle ! 💪
            </p>

        </div>

        <!-- Footer -->
        <div class="footer">
            <p>© 2026 <strong>Kinetic Pulse</strong> · Cotonou, Bénin</p>
            <p style="margin-top: 8px;">Cet email a été envoyé automatiquement, merci de ne pas y répondre.</p>
        </div>

    </div>
</body>
</html>